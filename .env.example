# Spotify Developer app credentials (required)
# Create an app at https://developer.spotify.com/dashboard
# and add http://127.0.0.1:8888/callback as a Redirect URI
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Kaggle API credentials (required for NBA ingestion)
# Create a token at https://www.kaggle.com/settings → "Create New Token"
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# DuckDB paths (optional — defaults resolve relative to the project root)
# Override only if storing files outside the default data/ directory.
# Must be absolute paths if set.
# DUCKDB_PATH=/absolute/path/to/data-world/data/spotify.duckdb
# CRYPTO_DB_PATH=/absolute/path/to/data-world/data/crypto_raw.duckdb
# LIVE_JSON_PATH=/absolute/path/to/data-world/data/live_data.json
# PAYMENTS_DB_PATH=/absolute/path/to/data-world/data/payments_raw.duckdb
