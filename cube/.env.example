# Cube environment variables: https://cube.dev/docs/reference/environment-variables
CUBEJS_DEV_MODE=true
CUBEJS_DB_TYPE=duckdb
# Generate your own with: openssl rand -hex 64
CUBEJS_API_SECRET=your_dev_secret
CUBEJS_EXTERNAL_DEFAULT=true
CUBEJS_SCHEDULED_REFRESH_DEFAULT=true
CUBEJS_SCHEMA_PATH=model
CUBEJS_WEB_SOCKETS=true

# Must be an absolute path (matches this repo's DuckDB path convention).
# The DuckDB driver always opens this file read-write (no read-only option) —
# don't run `task cube:dev` at the same time as `task dbt:run` or the Dagster
# spotify/nba ingest jobs, which also need write access to the same file.
CUBEJS_DB_DUCKDB_DATABASE_PATH=/absolute/path/to/data-world/data/spotify.duckdb
