# Verano learning-build configuration. Copy to verano/.env and adjust as needed.
# The data-generation scripts and dbt read VERANO_DUCKDB_PATH; keep it ABSOLUTE.

VERANO_DUCKDB_PATH=/Users/philkillarney/dev-env/data-world/verano/data/verano.duckdb

# Deterministic synthetic data. Change the seed for a different (still
# reproducible) dataset.
VERANO_SEED=42

# Simulated 6-month window. Default captures the pre-Christmas occasionwear
# spike + the post-Christmas sale/returns wave. Shift both dates by ~6 months
# (2026-05-01 .. 2026-10-31) to land on the summer wedding/occasion season.
VERANO_WINDOW_START=2025-11-01
VERANO_WINDOW_END=2026-04-30

# Embeddings backend for Stage 5: "tfidf" (default — scikit-learn TF-IDF + SVD, no
# heavy deps) or "sentence-transformers" (needs torch >= 2.4; unavailable on x86-64
# macOS, so only usable on Apple Silicon / Linux).
VERANO_EMBEDDINGS=tfidf
