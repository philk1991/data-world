# nao analytics agent environment variables.
# Copy to nao/.env and fill in. nao loads this file from the project directory
# (the `cd nao` in the Taskfile tasks ensures that), and resolves any
# ${{ env('VAR') }} references in nao_config.yaml against it.

# Absolute path to the shared DuckDB file that holds the dbt marts.
# Must be an absolute path (same convention as DUCKDB_PATH and
# CUBEJS_DB_DUCKDB_DATABASE_PATH). nao opens this READ-ONLY.
NAO_DUCKDB_PATH=/absolute/path/to/data-world/data/spotify.duckdb

# ── LLM provider ──────────────────────────────────────────────────────────────
# Left unset by default (see nao_config.yaml). The current nao release supports
# only OpenAI and Anthropic — no local Ollama provider yet. To enable chat,
# uncomment the matching key below AND set `llm:` in nao_config.yaml.
#
# This repo is Claude-native, so Anthropic is the natural first choice:
# ANTHROPIC_API_KEY=your_anthropic_api_key
#
# Or OpenAI:
# OPENAI_API_KEY=your_openai_api_key
#
# Advanced / experimental — route to a local OpenAI-compatible server (e.g.
# Ollama at http://localhost:11434/v1) with provider: openai. The chat binary
# reads OPENAI_BASE_URL, but its model list is hard-coded to cloud models, so
# this only works if a local model is aliased to one of those names. Unsupported.
# OPENAI_BASE_URL=http://localhost:11434/v1
